# -----------------------------------------------------------------------------
# Call-to-Lead Backend: Environment Configuration Example
# -----------------------------------------------------------------------------

# --- Server Settings ---
# The port the backend will listen on (default: 3000)
PORT=3000

# The public URL of your backend (required for Twilio webhooks)
# For local development, use an ngrok or similar proxy URL
APP_URL=http://localhost:3000

# --- Database ---
# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/rental-agency

# --- Security ---
# Secret key used for signing JWT tokens (use a strong random string)
JWT_SECRET=your_very_secure_and_long_jwt_secret_key

# --- Telephony (Twilio) ---
# Your Twilio Account SID (found in the Twilio Console)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Twilio Auth Token (found in the Twilio Console)
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# --- Cloudinary (File Storage) ---
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
